1 VERSIONINFO
FILEVERSION    @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
PRODUCTVERSION @PROJECT_VERSION_MAJOR@,@PROJECT_VERSION_MINOR@,@PROJECT_VERSION_PATCH@,0
FILEFLAGSMASK  0x3fL
FILEFLAGS      0x0L
FILEOS         0x40004L
FILETYPE       0x1L
FILESUBTYPE    0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName",      "BonjourServiceAdvertiser"
            VALUE "FileDescription",  "Bonjour Service Advertiser Windows Service"
            VALUE "FileVersion",      "@PROJECT_VERSION@"
            VALUE "InternalName",     "BonjourServiceAdvertiser"
            VALUE "LegalCopyright",   "Copyright 2026"
            VALUE "OriginalFilename", "BonjourServiceAdvertiser.exe"
            VALUE "ProductName",      "Bonjour Service Advertiser"
            VALUE "ProductVersion",   "@PROJECT_VERSION@"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
